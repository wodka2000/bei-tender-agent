# Telegram Bot credentials
# 1. Crea un bot su Telegram parlando con @BotFather → /newbot
# 2. Copia il token qui sotto
TELEGRAM_BOT_TOKEN=123456789:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 3. Per ottenere il tuo chat_id:
#    - Manda un messaggio al bot
#    - Apri: https://api.telegram.org/bot<TOKEN>/getUpdates
#    - Cerca "chat": {"id": XXXXXXXX} nel JSON
TELEGRAM_CHAT_ID=123456789
